{
  "name": "lingo",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "shared",
    "web",
    "mobile"
  ],
  "scripts": {
    "web": "npm run dev --workspace=web",
    "mobile": "npm run start --workspace=mobile",
    "build:web": "npm run build --workspace=web",
    "type-check": "npm run type-check --workspace=shared && npm run type-check --workspace=web"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "overrides": {
    "react-native-worklets": "~0.7.0"
  }
}
