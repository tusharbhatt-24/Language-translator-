{
  "expo": {
    "name": "Lingo",
    "slug": "lingo",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "lingo",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lingo.app"
    },
    "android": {
      "package": "com.lingo.app",
      "adaptiveIcon": {
        "backgroundColor": "#F5F0EB",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Lingo to access the microphone for speech-to-text translation.",
          "speechRecognitionPermission": "Allow Lingo to securely recognize your speech for translation."
        }
      ],
      "expo-build-properties"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
